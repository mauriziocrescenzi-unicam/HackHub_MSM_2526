<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
    <persistence-unit name="hackathonPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>it.unicam.cs.model.Hackathon</class>
        <class>it.unicam.cs.model.Giudice</class>
        <class>it.unicam.cs.model.Mentore</class>
        <class>it.unicam.cs.model.Organizzatore</class>
        <class>it.unicam.cs.model.Utente</class>
        <class>it.unicam.cs.model.Account</class>
        <class>it.unicam.cs.model.Team</class>
        <class>it.unicam.cs.model.TeamHackathon</class>
        <class>it.unicam.cs.model.MembroTeam</class>
        <class>it.unicam.cs.model.MembroTeamId</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:file:./HackHub_MSM/data/hackhub"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>